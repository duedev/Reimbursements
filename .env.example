# Copy this file to .env and set your preferred folder paths.
# If omitted, intake defaults to ./intake and output to ./output
# (relative to the directory where you run docker-compose).

# INTAKE_PATH=/Users/yourname/Desktop/receipts
# OUTPUT_PATH=/Users/yourname/Documents/reimbursements-output

# Optional shared-secret auth. Leave unset for an open localhost install. When
# set, every request must present this token (header X-Auth-Token, an auth_token
# cookie, or open the page once with ?token=<value>). Set this before exposing
# the app beyond 127.0.0.1.
# APP_AUTH_TOKEN=change-me-to-a-long-random-string

# Where the SMTP password / Dropbox token are stored. Defaults to a LOCAL
# (non cloud-synced) volume in Docker; never point this inside OUTPUT_PATH.
# SECRETS_PATH=/data/config/secrets.json
