# ── BUNDLED-LLM variant preset ───────────────────────────────────────────────
# Copy to .env and bring the app up with the bundled overlay:
#
#   cp .env.bundled.example .env
#   docker compose -f docker-compose.yml -f docker-compose.bundled.yml up --build
#
# This ALWAYS launches the in-Docker model-server (no external LM Studio needed).
# COMPOSE_PROFILES enables the profile-gated model-server service automatically, so
# `up` starts it without passing `--profile bundled-llm` on the command line.
COMPOSE_PROFILES=bundled-llm
LMSTUDIO_BASE_URL=http://model-server:1234/v1

# Bundled model weights are baked into the image (offline at runtime, ~2-3 GB).
# Defaults to unsloth Qwen3-VL-2B-Instruct (UD-Q5_K_XL) + its F16 vision projector.
# Uncomment to bake in a different GGUF + mmproj:
# MODEL_URL=https://huggingface.co/unsloth/Qwen3-VL-2B-Instruct-GGUF/resolve/main/Qwen3-VL-2B-Instruct-UD-Q5_K_XL.gguf
# MMPROJ_URL=https://huggingface.co/unsloth/Qwen3-VL-2B-Instruct-GGUF/resolve/main/mmproj-F16.gguf

# Folder paths (see .env.example for the full set). Defaults: ./intake, ./output.
# INTAKE_PATH=/path/to/receipts
# OUTPUT_PATH=/path/to/reimbursements-output

# Everything else (auth, multi-user, email, intake) is documented in .env.example.
