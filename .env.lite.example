# ── LITE variant preset ──────────────────────────────────────────────────────
# Copy to .env and bring the app up with the lite overlay (NO bundled model):
#
#   cp .env.lite.example .env
#   docker compose -f docker-compose.yml -f docker-compose.lite.yml up --build
#
# Use this when the model runs elsewhere. Pick ONE:
#
# 1) LM Studio (or any OpenAI-compatible server) on the HOST machine — the default:
LMSTUDIO_BASE_URL=http://host.docker.internal:1234/v1
#
# 2) OpenRouter cloud (free router) — leave LMSTUDIO_BASE_URL as-is and choose
#    "OpenRouter" in Settings → AI Model, or set OPENROUTER_API_KEY for zero-click
#    first-run selection (sends receipt data off-machine; opt-in):
# OPENROUTER_API_KEY=sk-or-...

# COMPOSE_PROFILES is intentionally left UNSET so the bundled model-server never
# builds or starts in this variant.

# Folder paths (see .env.example for the full set). Defaults: ./intake, ./output.
# INTAKE_PATH=/path/to/receipts
# OUTPUT_PATH=/path/to/reimbursements-output

# Everything else (auth, multi-user, email, intake) is documented in .env.example.
